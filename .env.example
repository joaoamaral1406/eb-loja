# ═══════════════════════════════════════════════════════
#  EB LOJA — Variáveis de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════

# ── STRIPE ───────────────────────────────────────────────
# Chave SECRETA (nunca mostrar para ninguém!)
# Painel Stripe → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook secret — preencher DEPOIS de criar o site no Railway
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── ROBLOX ───────────────────────────────────────────────
# Apenas para Gamepasses (entrega automática via Lua)
# Patentes e Divisões = entrega MANUAL avisada pelo Discord

# Universe ID do jogo
# Achar em: Studio → File → Game Settings → Basic Info → Universe ID
ROBLOX_UNIVERSE_ID=123456789

# API Key do Open Cloud (create.roblox.com/credentials)
# Permissão necessária: "Universe Messaging Service: Publish"
ROBLOX_OPEN_CLOUD_KEY=roblox_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── DISCORD ──────────────────────────────────────────────
# Canal #vendas → toda venda confirmada
DISCORD_WEBHOOK_VENDAS=https://discord.com/api/webhooks/XXXXX/XXXXX

# Canal #vendedores → patentes e divisões para entrega manual
DISCORD_WEBHOOK_VENDEDORES=https://discord.com/api/webhooks/XXXXX/XXXXX

# Canal #alertas → chargebacks e erros
DISCORD_WEBHOOK_ALERTAS=https://discord.com/api/webhooks/XXXXX/XXXXX

# ── APP ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# URL do Railway (preencher DEPOIS de criar o projeto lá)
FRONTEND_URL=https://SEU-PROJETO.up.railway.app

# Senha do painel admin (/admin.html)
ADMIN_SECRET=troque-por-uma-senha-forte-aqui
